<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Admin Message Board</title>
</head>
<body>

<h1>Admin Message Board</h1>

<% if (data && data.length > 0) { %>

    <% data.forEach((item)=>{ %>

        <div style="border:1px solid #ccc; padding:10px; margin:10px; position:relative;">
            
            <!-- Delete Button -->
            <form action="/delete-message/<%= item.notes.message_id %>" method="POST" 
                  style="position:absolute; right:10px; top:10px;">
                <button type="submit" style="background:red; color:white; border:none; padding:5px 8px;">
                    X
                </button>
            </form>

            <h3><%= item.notes.title %></h3>

            <p><%= item.notes.message %></p>

            <small>
                Posted by: <%= item.username %> <br>
                Date: <%= item.notes.created_at %>
            </small>

        </div>

    <% }) %>

<% } else { %>
    <p>No messages found.</p>
<% } %>

<button>
    <a href="/write-messages">Add New Message</a>
</button>

</body>
</html>
