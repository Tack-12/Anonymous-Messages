<!DOCTYPE html>
<html>
<head>
<title>Admin Message Board</title>
<link rel="stylesheet" href="/css/board.css">
</head>

<body>

<%- include("navbar") %>

<div class="board-container">

<% if (data && data.length > 0) { %>

<% data.forEach((item)=>{ %>

<div class="message-card">

<form action="/delete-message/<%= item.notes.message_id %>" method="POST">
<button class="delete-button">X</button>
</form>

<h3><%= item.notes.title %></h3>

<p><%= item.notes.message %></p>

<div class="message-meta">
Posted by: <%= item.username %> <br>
Date: <%= item.notes.created_at %>
</div>

</div>

<% }) %>

<% } else { %>

<p>No messages found.</p>

<% } %>

<div class="add-message">
<a href="/write-messages">Add New Message</a>
</div>

</div>

</body>
</html>
